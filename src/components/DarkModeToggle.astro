---
// Dark mode toggle button — reads/writes to localStorage & toggles .dark class
---

<button
  id="dark-mode-toggle"
  type="button"
  aria-label="Farbmodus wechseln"
  class="inline-flex items-center justify-center p-2 rounded-md text-forest-100 hover:text-white hover:bg-forest-800 transition-colors"
>
  <!-- Sun icon (visible in dark mode) -->
  <svg
    id="icon-sun"
    class="w-5 h-5 hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
    ></path>
  </svg>
  <!-- Moon icon (visible in light mode) -->
  <svg
    id="icon-moon"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
    ></path>
  </svg>
</button>

<script>
  function initDarkMode() {
    const toggle = document.getElementById("dark-mode-toggle");
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");

    function updateIcons() {
      const isDark = document.documentElement.classList.contains("dark");
      iconSun?.classList.toggle("hidden", !isDark);
      iconMoon?.classList.toggle("hidden", isDark);
    }

    // Apply stored preference or system preference on load
    const stored = localStorage.getItem("theme");
    if (
      stored === "dark" ||
      (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
    ) {
      document.documentElement.classList.add("dark");
    }
    updateIcons();

    toggle?.addEventListener("click", () => {
      document.documentElement.classList.toggle("dark");
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateIcons();
    });
  }

  // Run on initial load and after View Transitions
  initDarkMode();
  document.addEventListener("astro:after-swap", initDarkMode);
</script>
