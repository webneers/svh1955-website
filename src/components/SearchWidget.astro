---
// Pagefind search — full-text search powered by static index
---

<button
  id="search-toggle"
  type="button"
  aria-label="Suche öffnen"
  class="inline-flex items-center justify-center p-2 rounded-md text-forest-100 hover:text-white hover:bg-forest-800 transition-colors"
>
  <svg
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
    ></path>
  </svg>
</button>

<!-- Pagefind modal -->
<div
  id="search-modal"
  class="hidden fixed inset-0 z-[100] bg-forest-950/60 backdrop-blur-sm"
>
  <div class="max-w-xl mx-auto mt-20 px-4">
    <div id="pagefind-container"></div>
    <p class="text-center text-xs text-white/50 mt-3">ESC zum Schließen</p>
  </div>
</div>

<script is:inline>
  var pagefindUI = null;

  function initSearch() {
    var toggle = document.getElementById("search-toggle");
    var modal = document.getElementById("search-modal");

    function openSearch() {
      if (modal) modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";

      // Lazy-load Pagefind UI on first open
      if (!pagefindUI) {
        var script = document.createElement("script");
        script.src = "/pagefind/pagefind-ui.js";
        script.onload = function () {
          pagefindUI = new window.PagefindUI({
            element: "#pagefind-container",
            showSubResults: true,
            showImages: false,
            translations: {
              placeholder: "Seite suchen\u2026",
              zero_results:
                "Keine Ergebnisse f\u00FCr \u201E[SEARCH_TERM]\u201C",
            },
          });
          setTimeout(function () {
            var input = document.querySelector(
              "#pagefind-container .pagefind-ui__search-input",
            );
            if (input) input.focus();
          }, 100);
        };
        script.onerror = function () {
          var container = document.getElementById("pagefind-container");
          if (container) {
            container.innerHTML =
              '<p style="padding:1.5rem;text-align:center;color:#9ca3af;font-size:0.875rem;">' +
              'Suchindex nicht gefunden. Bitte einmal <code style="background:#f3f4f6;padding:0.125rem 0.375rem;border-radius:0.25rem;">pnpm run build</code> ausf\u00FChren.</p>';
          }
        };
        document.head.appendChild(script);
      } else {
        setTimeout(function () {
          var input = document.querySelector(
            "#pagefind-container .pagefind-ui__search-input",
          );
          if (input) input.focus();
        }, 50);
      }
    }

    function closeSearch() {
      if (modal) modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    if (toggle) toggle.addEventListener("click", openSearch);
    if (modal)
      modal.addEventListener("click", function (e) {
        if (e.target === modal) closeSearch();
      });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openSearch();
      }
    });
  }

  initSearch();
</script>

<style is:global>
  /* Pagefind UI theme overrides */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--color-gold-500);
    --pagefind-ui-text: var(--color-forest-900);
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: var(--color-sand-200);
    --pagefind-ui-tag: var(--color-sand-100);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-font: var(--font-family-body);
  }

  .dark {
    --pagefind-ui-text: var(--color-sand-100);
    --pagefind-ui-background: var(--color-forest-900);
    --pagefind-ui-border: var(--color-forest-700);
    --pagefind-ui-tag: var(--color-forest-800);
  }

  .pagefind-ui__search-input {
    font-size: 1.125rem !important;
    padding: 0.875rem 1rem !important;
  }

  .pagefind-ui__result-link {
    color: var(--color-gold-500) !important;
  }

  .pagefind-ui__result-link:hover {
    color: var(--color-gold-400) !important;
  }
</style>
