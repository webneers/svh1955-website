---
import "../styles/global.css";
import { Image } from "astro:assets";
import SEO from "../components/SEO.astro";
import DarkModeToggle from "../components/DarkModeToggle.astro";
import SearchWidget from "../components/SearchWidget.astro";
import wappenImage from "../assets/wappen1.jpg";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string;
}

const {
  title = "Schützenverein Hochdorf 1955 e.V.",
  description = "Tradition, Präzision und Gemeinschaft im Schützensport.",
  image,
  type,
  publishedDate,
} = Astro.props;

const navItems = [
  { href: "/verein", label: "Verein" },
  { href: "/chronik", label: "Chronik" },
  { href: "/schuetzenhaus", label: "Schützenhaus" },
  { href: "/mitgliedschaft", label: "Mitgliedschaft" },
  { href: "/kontakt", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1b2e1b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
    />
    <title>{title}</title>
    <script is:inline>
      // Prevent FOUC: apply dark mode before paint
      (function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-sand-50 dark:bg-forest-950 text-forest-950 dark:text-sand-100 font-body min-h-screen flex flex-col antialiased"
  >
    <!-- Top accent bar -->
    <div
      class="h-1 bg-gradient-to-r from-forest-800 via-gold-500 to-forest-800"
    >
    </div>

    <header class="bg-forest-900 text-white sticky top-0 z-50 shadow-lg">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Desktop header -->
        <div class="flex items-center justify-between h-16 lg:h-20">
          <a href="/" class="flex items-center gap-3 group">
            <Image
              src={wappenImage}
              alt="Vereinswappen"
              width={40}
              height={40}
              format="webp"
              quality={80}
              class="w-10 h-10 rounded-full border-2 border-gold-500/40 object-cover hidden sm:block"
            />
            <div class="flex flex-col">
              <span
                class="text-gold-400 text-[0.65rem] sm:text-xs font-semibold tracking-[0.2em] uppercase"
              >
                Seit 1955
              </span>
              <span
                class="text-lg sm:text-xl font-heading font-bold tracking-wide group-hover:text-gold-300 transition-colors duration-200"
              >
                SV Hochdorf
              </span>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <nav aria-label="Hauptnavigation" class="hidden lg:block">
            <ul class="flex items-center gap-1">
              {
                navItems.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "px-3 py-2 rounded-md text-sm font-medium transition-all duration-200",
                        currentPath === item.href ||
                        (item.href !== "/" && currentPath.startsWith(item.href))
                          ? "bg-forest-700/60 text-gold-300"
                          : "text-forest-100 hover:bg-forest-800 hover:text-white",
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <!-- Header actions -->
          <div class="flex items-center gap-1">
            <SearchWidget />
            <DarkModeToggle />

            <!-- Mobile menu button -->
            <button
              id="mobile-menu-btn"
              type="button"
              class="lg:hidden inline-flex items-center justify-center p-2 rounded-md text-forest-100 hover:text-white hover:bg-forest-800 transition-colors"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <span class="sr-only">Menü öffnen</span>
              <!-- Hamburger icon -->
              <svg
                id="menu-icon-open"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
              </svg>
              <!-- Close icon -->
              <svg
                id="menu-icon-close"
                class="h-6 w-6 hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <nav
        id="mobile-menu"
        class="lg:hidden hidden border-t border-forest-700/50"
        aria-label="Mobile Navigation"
      >
        <div class="px-4 pt-2 pb-4 space-y-1">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "block px-3 py-2 rounded-md text-base font-medium transition-colors",
                  currentPath === item.href ||
                  (item.href !== "/" && currentPath.startsWith(item.href))
                    ? "bg-forest-700/60 text-gold-300"
                    : "text-forest-100 hover:bg-forest-800 hover:text-white",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-forest-900 text-forest-100 mt-auto">
      <div
        class="h-px bg-gradient-to-r from-transparent via-gold-500 to-transparent"
      >
      </div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Club info -->
          <div>
            <h3 class="font-heading text-white font-bold text-lg mb-2">
              SV Hochdorf 1955 e.V.
            </h3>
            <p class="text-sm text-forest-100/70 leading-relaxed">
              Tradition, Präzision und Gemeinschaft<br />im Schützensport seit
              1955.
            </p>
          </div>
          <!-- Quick links -->
          <div>
            <h3 class="font-heading text-white font-bold text-lg mb-2">
              Navigation
            </h3>
            <ul class="space-y-1 text-sm">
              <li>
                <a href="/verein" class="hover:text-gold-400 transition-colors"
                  >Verein</a
                >
              </li>
              <li>
                <a
                  href="/schuetzenhaus"
                  class="hover:text-gold-400 transition-colors">Schützenhaus</a
                >
              </li>
              <li>
                <a
                  href="/mitgliedschaft"
                  class="hover:text-gold-400 transition-colors"
                  >Mitglied werden</a
                >
              </li>
              <li>
                <a href="/kontakt" class="hover:text-gold-400 transition-colors"
                  >Kontakt</a
                >
              </li>
            </ul>
          </div>
          <!-- Legal -->
          <div>
            <h3 class="font-heading text-white font-bold text-lg mb-2">
              Rechtliches
            </h3>
            <ul class="space-y-1 text-sm">
              <li>
                <a
                  href="/impressum"
                  class="hover:text-gold-400 transition-colors">Impressum</a
                >
              </li>
              <li>
                <a
                  href="/datenschutz"
                  class="hover:text-gold-400 transition-colors">Datenschutz</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div
          class="mt-8 pt-6 border-t border-forest-800 text-center text-sm text-forest-100/50"
        >
          © {new Date().getFullYear()} Schützenverein Hochdorf 1955 e.V. — Alle Rechte
          vorbehalten.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");

      btn?.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!expanded));
        menu?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
      });
    </script>
  </body>
</html>
