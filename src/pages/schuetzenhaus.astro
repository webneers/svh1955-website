---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Schützenhaus">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Schützenhaus</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Unser Schützenhaus auf der Sandhalde
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Das Vereinsheim ist sportlicher und gesellschaftlicher Mittelpunkt.
        Gäste und Mitglieder sind zu unseren Öffnungszeiten herzlich willkommen.
      </p>
    </div>
  </section>

  <!-- Gaststätte photos -->
  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 mb-8 relative z-10"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <img
        src="/img/Gaststaette_600_2.jpg"
        alt="Gaststätte Innenansicht"
        class="rounded-xl shadow-lg w-full h-48 sm:h-56 object-cover"
      />
      <img
        src="/img/Gaststaette_600_3.jpg"
        alt="Gaststätte Außenansicht"
        class="rounded-xl shadow-lg w-full h-48 sm:h-56 object-cover"
      />
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <!-- Öffnungszeiten -->
      <article
        class="bg-white rounded-xl shadow-md border border-sand-200 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 mb-3">
          Öffnungszeiten Gaststätte
        </h2>
        <ul class="space-y-2 text-sm text-forest-700/70">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-gold-500 rounded-full shrink-0"
            ></span>Sonntag zum Frühschoppen ab 10:00 Uhr
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-gold-500 rounded-full shrink-0"
            ></span>Jede zweite Woche am Dienstag ab 14:00 Uhr
          </li>
        </ul>
      </article>

      <!-- 10m Bahn -->
      <article
        class="bg-white rounded-xl shadow-md border border-sand-200 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-forest-700"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7.5 3.75H6A2.25 2.25 0 003.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0120.25 6v1.5m0 9V18A2.25 2.25 0 0118 20.25h-1.5m-9 0H6A2.25 2.25 0 013.75 18v-1.5"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 mb-3">
          10-Meter-Bahn
        </h2>
        <p class="text-sm text-forest-700/70 leading-relaxed">
          Disziplinen: Luftgewehr und Luftpistole.
        </p>
      </article>

      <!-- Weitere Anlagen -->
      <article
        class="bg-white rounded-xl shadow-md border border-sand-200 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-forest-700"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 mb-3">
          Weitere Anlagen
        </h2>
        <p class="text-sm text-forest-700/70 leading-relaxed">
          25 m, 50 m und 100 m Bahnen für Training und Wettkampf.
        </p>
      </article>

      <!-- Adresse -->
      <article
        class="bg-gradient-to-br from-forest-900 to-forest-800 text-white rounded-xl shadow-md p-6"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/20 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg mb-3">Adresse</h2>
        <p class="text-forest-100/80 text-sm">
          Mühlenstraße 46<br />72202 Nagold-Hochdorf
        </p>
      </article>
    </div>
  </section>
</Layout>
