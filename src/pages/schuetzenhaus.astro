---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Schützenhaus">
  <section class="hero">
    <p class="eyebrow">Schützenhaus</p>
    <h1>Unser Schützenhaus auf der Sandhalde</h1>
    <p>
      Das Vereinsheim ist sportlicher und gesellschaftlicher Mittelpunkt. Gäste
      und Mitglieder sind zu unseren Öffnungszeiten herzlich willkommen.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Öffnungszeiten Gaststätte</h2>
      <p>Sonntag zum Frühschoppen ab 10:00 Uhr.</p>
      <p>Jede zweite Woche am Dienstag ab 14:00 Uhr.</p>
    </article>
    <article class="card">
      <h2>10-Meter-Bahn</h2>
      <p>Disziplinen: Luftgewehr und Luftpistole.</p>
    </article>
    <article class="card">
      <h2>Weitere Anlagen</h2>
      <p>25 m, 50 m und 100 m Bahnen für Training und Wettkampf.</p>
    </article>
    <article class="card">
      <h2>Adresse</h2>
      <p>Mühlenstraße 46 · 72202 Nagold-Hochdorf</p>
    </article>
  </section>
</Layout>
