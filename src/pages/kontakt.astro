---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Kontakt">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Kontakt</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        So erreichst du uns
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Für Fragen zu Training, Mitgliedschaft oder Veranstaltungen melde dich
        gerne bei unserer Vorstandschaft.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Anschrift -->
      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-3">
          Anschrift
        </h2>
        <p class="text-sm text-forest-700/70 dark:text-forest-100/60 font-medium">
          Schützenverein Hochdorf 1955 e.V.
        </p>
        <p class="text-sm text-forest-700/70 dark:text-forest-100/60">
          Mühlenstraße 46<br />72202 Nagold-Hochdorf
        </p>
      </article>

      <!-- Vorstandschaft -->
      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-forest-700 dark:text-forest-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-3">
          Vorstandschaft
        </h2>
        <div class="space-y-2 text-sm text-forest-700/70 dark:text-forest-100/60">
          <p>
            <span class="font-medium text-forest-900 dark:text-white">1. Vorsitzender:</span> Klaus
            Blümle
          </p>
          <p>
            <span class="font-medium text-forest-900 dark:text-white">2. Vorsitzender:</span> Dieter
            Gack
          </p>
        </div>
      </article>

      <!-- Trainingsanfragen -->
      <article
        class="bg-gradient-to-br from-forest-900 to-forest-800 text-white rounded-xl shadow-md p-6"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/20 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg mb-3">Trainingsanfragen</h2>
        <p class="text-sm text-forest-100/70 mb-4">
          Bitte gib Disziplin und Altersgruppe an, damit wir schnell antworten
          können.
        </p>
        <a
          href="mailto:kontakt@svh1955.de"
          class="inline-flex items-center gap-2 px-4 py-2 bg-gold-500 hover:bg-gold-400 text-forest-950 font-semibold text-sm rounded-lg transition-colors"
        >
          kontakt@svh1955.de
        </a>
      </article>
    </div>
  </section>
</Layout>
