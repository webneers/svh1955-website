---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Kontakt">
  <section class="hero">
    <p class="eyebrow">Kontakt</p>
    <h1>So erreichst du uns</h1>
    <p>
      Für Fragen zu Training, Mitgliedschaft oder Veranstaltungen melde dich
      gerne bei unserer Vorstandschaft.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Anschrift</h2>
      <p>Schützenverein Hochdorf 1955 e.V.</p>
      <p>Mühlenstraße 46<br />72202 Nagold-Hochdorf</p>
    </article>
    <article class="card">
      <h2>E-Mail</h2>
      <p>kontakt@svh1955.de</p>
    </article>
    <article class="card">
      <h2>Trainingsanfragen</h2>
      <p>
        Bitte gib Disziplin und Altersgruppe an, damit wir schnell antworten
        können.
      </p>
    </article>
  </section>
</Layout>
