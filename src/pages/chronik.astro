---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Chronik">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Chronik</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Aus unserer Vereinsgeschichte
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Auszüge aus der Historie des Schützenvereins Hochdorf 1955 e.V. von der
        Gründung bis in die 2000er Jahre.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-gradient-to-b from-gold-500 via-forest-600 to-forest-800"
      >
      </div>

      <!-- 1955-1969 -->
      <div
        class="relative flex items-start mb-12 md:even:flex-row-reverse group"
      >
        <div
          class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-gold-500 border-4 border-sand-50 dark:border-forest-950 shadow z-10"
        >
        </div>
        <div class="ml-12 md:ml-0 md:w-1/2 md:pr-12">
          <div
            class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow"
          >
            <span
              class="inline-block px-2 py-0.5 text-xs font-bold tracking-wider uppercase text-gold-500 bg-gold-500/10 rounded mb-3"
              >1955–1969</span
            >
            <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
              Gründung & Aufbau
            </h2>
            <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
              Gründung 1955 in der Gaststätte zum Hirsch, erste
              Pokalwettbewerbe, Beginn des Übungsschießens, Aufbau der Anlagen
              auf der Sandhalde und Erweiterungspläne mit viel Eigenleistung.
            </p>
          </div>
        </div>
      </div>

      <!-- 1970er -->
      <div class="relative flex items-start mb-12 group">
        <div
          class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-forest-600 border-4 border-sand-50 dark:border-forest-950 shadow z-10"
        >
        </div>
        <div class="ml-12 md:ml-auto md:w-1/2 md:pl-12">
          <div
            class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow"
          >
            <span
              class="inline-block px-2 py-0.5 text-xs font-bold tracking-wider uppercase text-forest-700 dark:text-forest-300 bg-forest-100 dark:bg-forest-800 rounded mb-3"
              >1970er Jahre</span
            >
            <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
              Sportliche Erfolge
            </h2>
            <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
              Sportliche Erfolge im Luftgewehrbereich, Aufstieg in hohe Klassen,
              Kreis- und Meisterschaftserfolge sowie Ausbau der
              Freundschaftskämpfe.
            </p>
          </div>
        </div>
      </div>

      <!-- 1980er -->
      <div class="relative flex items-start mb-12 group">
        <div
          class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-forest-600 border-4 border-sand-50 dark:border-forest-950 shadow z-10"
        >
        </div>
        <div class="ml-12 md:ml-0 md:w-1/2 md:pr-12">
          <div
            class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow"
          >
            <span
              class="inline-block px-2 py-0.5 text-xs font-bold tracking-wider uppercase text-forest-700 dark:text-forest-300 bg-forest-100 dark:bg-forest-800 rounded mb-3"
              >1980er Jahre</span
            >
            <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
              Jubiläen & Modernisierung
            </h2>
            <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
              Jubiläen, Modernisierung der Anlagen, enge Zusammenarbeit mit
              örtlichen Vereinen und internationale Begegnungen mit Longwy.
            </p>
          </div>
        </div>
      </div>

      <!-- 1990er-2003 -->
      <div class="relative flex items-start group">
        <div
          class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-forest-800 border-4 border-sand-50 dark:border-forest-950 shadow z-10"
        >
        </div>
        <div class="ml-12 md:ml-auto md:w-1/2 md:pl-12">
          <div
            class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow"
          >
            <span
              class="inline-block px-2 py-0.5 text-xs font-bold tracking-wider uppercase text-forest-700 dark:text-forest-300 bg-forest-100 dark:bg-forest-800 rounded mb-3"
              >1990er bis 2003</span
            >
            <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
              Weiterentwicklung
            </h2>
            <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
              Weitere Modernisierungen (10 m, 25 m, Gaststätte), starke
              Jugendarbeit, Vereinsfeste und kontinuierliche Weiterentwicklung
              des Schützenhauses.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
