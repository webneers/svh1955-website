---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Ergebnisse">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Wettkampf</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Ergebnisse & Leistungen
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Hier veröffentlichen wir aktuelle Ergebnisse aus Liga, Meisterschaften
        und internen Wettkämpfen.
      </p>
    </div>
  </section>

  <!-- Championship photo -->
  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 mb-8 relative z-10"
  >
    <figure class="relative rounded-xl overflow-hidden shadow-lg">
      <img
        src="/img/Hochdorf-KOL-Meister-2018-1.jpg"
        alt="KOL-Meister 2018 – SV Hochdorf Mannschaftsfoto"
        class="w-full h-48 sm:h-64 object-cover"
      />
      <figcaption
        class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-forest-950/80 to-transparent px-4 py-3 text-sm text-white/80"
      >
        KOL-Meister 2018 – Unsere erfolgreiche Mannschaft
      </figcaption>
    </figure>
  </section>

  <!-- Content -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Luftgewehr -->
      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-gold-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
              ></path>
            </svg>
          </div>
          <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white">
            Luftgewehr
          </h2>
        </div>
        <div class="space-y-3 text-sm text-forest-700/70 dark:text-forest-100/60">
          <div class="bg-sand-50 dark:bg-forest-800/50 rounded-lg p-3">
            <p
              class="font-semibold text-forest-900 dark:text-white text-xs uppercase tracking-wide mb-1"
            >
              Bezirksliga B 2018/19
            </p>
            <p>Hochdorf gelang der zweite Aufstieg in Folge.</p>
          </div>
          <div class="bg-sand-50 dark:bg-forest-800/50 rounded-lg p-3">
            <p
              class="font-semibold text-forest-900 dark:text-white text-xs uppercase tracking-wide mb-1"
            >
              Pokalrunde A
            </p>
            <p>SV Hochdorf 1 auf Platz 6 (Ø 1.488,3 Ringe).</p>
          </div>
        </div>
      </article>

      <!-- Luftpistole -->
      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-forest-700 dark:text-forest-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
              ></path>
            </svg>
          </div>
          <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white">
            Luftpistole
          </h2>
        </div>
        <div class="space-y-3 text-sm text-forest-700/70 dark:text-forest-100/60">
          <div class="bg-sand-50 dark:bg-forest-800/50 rounded-lg p-3">
            <p
              class="font-semibold text-forest-900 dark:text-white text-xs uppercase tracking-wide mb-1"
            >
              Kreisliga 2018/19
            </p>
            <p>SV Hochdorf auf Platz 2 (Ø 1.369,0 Ringe).</p>
          </div>
          <p class="text-xs">
            Top-Einzelschützen u.a. Nico Haizmann und Klaus Blümle.
          </p>
        </div>
      </article>

      <!-- Einzelergebnisse -->
      <article
        class="bg-gradient-to-br from-forest-900 to-forest-800 text-white rounded-xl shadow-md p-6"
      >
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-10 h-10 rounded-lg bg-gold-500/20 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-gold-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
              ></path>
            </svg>
          </div>
          <h2 class="font-heading font-bold text-lg">Einzelergebnisse</h2>
        </div>
        <div class="space-y-3 text-sm">
          <div class="bg-white/10 rounded-lg p-3">
            <p
              class="font-semibold text-gold-300 text-xs uppercase tracking-wide mb-1"
            >
              Luftgewehr
            </p>
            <p class="text-forest-100/80">
              Jens Haizmann Ø 375,2 · Martin Braunhuber Ø 373,0
            </p>
          </div>
          <div class="bg-white/10 rounded-lg p-3">
            <p
              class="font-semibold text-gold-300 text-xs uppercase tracking-wide mb-1"
            >
              Luftpistole
            </p>
            <p class="text-forest-100/80">
              Nico Haizmann Ø 354,2 · Klaus Blümle Ø 348,5
            </p>
          </div>
        </div>
      </article>
    </div>
  </section>
</Layout>
