---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Ergebnisse">
  <section class="hero">
    <p class="eyebrow">Wettkampf</p>
    <h1>Ergebnisse & Leistungen</h1>
    <p>
      Hier veröffentlichen wir aktuelle Ergebnisse aus Liga, Meisterschaften und
      internen Wettkämpfen.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Luftgewehr</h2>
      <p>Bezirksliga B · Aktuelle Saisonstände und Mannschaftsergebnisse.</p>
    </article>
    <article class="card">
      <h2>Luftpistole</h2>
      <p>Rundenwettkämpfe und Meisterschaftsergebnisse der aktiven Schützen.</p>
    </article>
    <article class="card">
      <h2>Archiv</h2>
      <p>
        Historische Ergebnisse und besondere sportliche Erfolge aus früheren
        Jahren.
      </p>
    </article>
  </section>
</Layout>
