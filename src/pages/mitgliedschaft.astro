---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Mitgliedschaft">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Mitmachen</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Mitglied werden
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Wir freuen uns über neue Schützinnen und Schützen jeden Alters. Ein
        Probetraining ist nach Absprache jederzeit möglich.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
          Probetraining
        </h2>
        <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
          Einfach Kontakt aufnehmen und einen Termin mit unserer Schießleitung
          abstimmen.
        </p>
      </article>

      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-forest-700 dark:text-forest-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
          Mitgliedsantrag
        </h2>
        <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
          Der Antrag wird hier als Download bereitgestellt.
        </p>
      </article>

      <article
        class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-6 hover:shadow-lg transition-shadow duration-300"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-forest-700 dark:text-forest-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2">
          Jugend & Erwachsene
        </h2>
        <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed">
          Betreute Trainingszeiten für Einsteiger und erfahrene Sportschützen.
        </p>
      </article>
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <a
        href="/kontakt"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gold-500 hover:bg-gold-400 text-forest-950 font-semibold rounded-lg shadow-md hover:shadow-lg transition-all duration-200"
      >
        Kontakt aufnehmen
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
        >
      </a>
    </div>
  </section>
</Layout>
