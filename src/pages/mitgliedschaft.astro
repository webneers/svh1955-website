---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Mitgliedschaft">
  <section class="hero">
    <p class="eyebrow">Mitmachen</p>
    <h1>Mitglied werden</h1>
    <p>
      Wir freuen uns über neue Schützinnen und Schützen jeden Alters. Ein
      Probetraining ist nach Absprache jederzeit möglich.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Probetraining</h2>
      <p>
        Einfach Kontakt aufnehmen und einen Termin mit unserer Schießleitung
        abstimmen.
      </p>
    </article>
    <article class="card">
      <h2>Mitgliedsantrag</h2>
      <p>Der Antrag wird hier als Download bereitgestellt.</p>
    </article>
    <article class="card">
      <h2>Jugend & Erwachsene</h2>
      <p>
        Betreute Trainingszeiten für Einsteiger und erfahrene Sportschützen.
      </p>
    </article>
  </section>
</Layout>
