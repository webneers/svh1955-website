---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("aktuelles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="SV Hochdorf 1955 – Aktuelles">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Aktuelles</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Neuigkeiten aus dem Vereinsleben
      </h1>
      <p class="text-lg text-forest-100/80 max-w-2xl">
        Ankündigungen, Hinweise zum Schießbetrieb und Meldungen rund um
        Wettkämpfe und Veranstaltungen.
      </p>
    </div>
  </section>

  <!-- Posts list -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="space-y-6">
      {posts.map((post) => (
        <a href={`/aktuelles/${post.id.replace(/\.mdx?$/, "")}`} class="group block bg-white dark:bg-forest-900 rounded-xl shadow-md hover:shadow-xl border border-sand-200 dark:border-forest-700 p-6 sm:p-8 transition-all duration-300 hover:-translate-y-0.5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center shrink-0 mt-1">
              <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <time class="text-xs font-medium text-forest-600/60 dark:text-forest-100/50 uppercase tracking-wider">
                {post.data.date.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <h2 class="font-heading font-bold text-xl text-forest-900 dark:text-white mt-1 mb-2 group-hover:text-gold-500 transition-colors">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              )}
              <span class="inline-flex items-center gap-1 mt-3 text-sm font-medium text-gold-500">
                Weiterlesen
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-12 text-forest-600/60 dark:text-forest-100/50">
        <p>Aktuell keine Neuigkeiten.</p>
      </div>
    )}
  </section>
</Layout>
