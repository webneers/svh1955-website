---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Verein">
  <section class="hero">
    <p class="eyebrow">Verein</p>
    <h1>Über unseren Verein</h1>
    <p>
      Gegründet im Jahr 1955, steht der Schützenverein Hochdorf e.V. für
      generationsübergreifenden Schießsport und gelebte Dorfgemeinschaft.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Vorstand</h2>
      <p>
        Informationen zur aktuellen Vorstandschaft folgen hier in strukturierter
        Form.
      </p>
    </article>
    <article class="card">
      <h2>Chronik</h2>
      <p>
        Unsere Vereinsgeschichte von der Gründung bis heute wird in einer
        eigenen Chronikseite aufbereitet.
      </p>
    </article>
    <article class="card">
      <h2>Dokumente</h2>
      <p>
        Satzung, Mitgliedsantrag und weitere Vereinsunterlagen werden digital
        bereitgestellt.
      </p>
    </article>
  </section>
</Layout>
