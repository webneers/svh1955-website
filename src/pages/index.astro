---
import Layout from "../layouts/Layout.astro";
import MapHero from "../components/MapHero.astro";
---

<Layout title="SV Hochdorf 1955 – Startseite">
  <!-- Hero -->
  <section
    class="relative bg-gradient-to-br from-forest-900 via-forest-800 to-forest-900 text-white overflow-hidden"
  >
    <!-- Decorative rings pattern -->
    <div class="absolute inset-0 opacity-5">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border-[3px] border-white rounded-full"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border-[3px] border-white rounded-full"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200px] h-[200px] border-[3px] border-white rounded-full"
      >
      </div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-6"
      >
        Willkommen
      </span>
      <h1
        class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6"
      >
        Schützenverein<br />
        <span class="text-gold-400">Hochdorf 1955</span> e.V.
      </h1>
      <p
        class="text-lg sm:text-xl text-forest-100/80 max-w-2xl leading-relaxed mb-8"
      >
        Hallo Schützenfreunde, herzlich willkommen auf unserer Website. Wir
        verbinden sportlichen Anspruch mit aktiver Vereinskultur und gelebter
        Dorfgemeinschaft.
      </p>
      <div class="flex items-center gap-4">
        <img
          src="/img/vorstand/klaus.jpg"
          alt="Klaus Blümle, 1. Vorstand"
          class="w-14 h-14 rounded-full border-2 border-gold-500/40 object-cover"
        />
        <p class="text-sm text-forest-100/60 italic">
          Grußwort der Vorstandschaft<br />Klaus Blümle (1. Vorstand)
        </p>
      </div>
    </div>
  </section>

  <!-- Quick-access cards -->
  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16"
    aria-label="Schnelleinstieg"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Kontakt & Anfahrt -->
      <a
        href="/kontakt"
        class="group block bg-white dark:bg-forest-900 rounded-xl shadow-md hover:shadow-xl border border-sand-200 dark:border-forest-700 p-6 transition-all duration-300 hover:-translate-y-1"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mb-4 group-hover:bg-gold-500/20 transition-colors"
        >
          <svg
            class="w-5 h-5 text-gold-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"
            ></path>
          </svg>
        </div>
        <h2
          class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2 group-hover:text-gold-500 transition-colors"
        >
          Kontakt & Anfahrt
        </h2>
        <p
          class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed"
        >
          Adresse, Ansprechpartner und direkte Navigation zum Schützenhaus.
        </p>
        <span
          class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-gold-500"
        >
          Route planen
          <svg
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
          >
        </span>
      </a>

      <!-- Nächste Termine -->
      <a
        href="/schuetzenhaus"
        class="group block bg-white dark:bg-forest-900 rounded-xl shadow-md hover:shadow-xl border border-sand-200 dark:border-forest-700 p-6 transition-all duration-300 hover:-translate-y-1"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center mb-4 group-hover:bg-forest-800/10 transition-colors"
        >
          <svg
            class="w-5 h-5 text-forest-700 dark:text-forest-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
            ></path>
          </svg>
        </div>
        <h2
          class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2 group-hover:text-gold-500 transition-colors"
        >
          Nächste Termine
        </h2>
        <p
          class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed"
        >
          Sonntag Frühschoppen und Vereinsbetrieb ab 10:00 Uhr auf der
          Sandhalde.
        </p>
        <span
          class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-gold-500"
        >
          Mehr zum Schützenhaus
          <svg
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
          >
        </span>
      </a>

      <!-- Verein -->
      <a
        href="/verein"
        class="group block bg-white dark:bg-forest-900 rounded-xl shadow-md hover:shadow-xl border border-sand-200 dark:border-forest-700 p-6 transition-all duration-300 hover:-translate-y-1"
      >
        <div
          class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-800 flex items-center justify-center mb-4 group-hover:bg-forest-800/10 transition-colors"
        >
          <svg
            class="w-5 h-5 text-forest-700 dark:text-forest-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
            ></path>
          </svg>
        </div>
        <h2
          class="font-heading font-bold text-lg text-forest-900 dark:text-white mb-2 group-hover:text-gold-500 transition-colors"
        >
          Verein
        </h2>
        <p
          class="text-sm text-forest-700/70 dark:text-forest-100/60 leading-relaxed"
        >
          Alles Wichtige zu Geschichte, Vorstandschaft und Vereinsleben.
        </p>
        <span
          class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-gold-500"
        >
          Mehr über uns
          <svg
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
          >
        </span>
      </a>

      <!-- Neu dabei? -->
      <a
        href="/mitgliedschaft"
        class="group block bg-gradient-to-br from-forest-900 to-forest-800 text-white rounded-xl shadow-md hover:shadow-xl p-6 transition-all duration-300 hover:-translate-y-1"
      >
        <div
          class="w-10 h-10 rounded-lg bg-gold-500/20 flex items-center justify-center mb-4"
        >
          <svg
            class="w-5 h-5 text-gold-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"
            ></path>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-lg mb-2">Neu dabei?</h2>
        <p class="text-sm text-forest-100/70 leading-relaxed">
          Informiere dich über Probetraining, Ausrüstung und den
          Mitgliedsantrag.
        </p>
        <span
          class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-gold-400"
        >
          Mitglied werden
          <svg
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
          >
        </span>
      </a>
    </div>
  </section>

  <MapHero
    title="Anfahrt"
    address="Schützenverein Hochdorf 1955 e.V., Sandhalde 2, 72202 Nagold"
    embedUrl="https://www.openstreetmap.org/export/embed.html?bbox=8.70302356671485%2C48.48861298345707%2C8.72302356671485%2C48.50861298345707&layer=mapnik&marker=48.49861298345707%2C8.713023566714849"
    ctaUrl="https://www.google.com/maps/dir/?api=1&destination=48.49861298345707%2C8.713023566714849"
    ctaLabel="In Google Maps öffnen (Navigation)"
  />
</Layout>
