---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Startseite">
  <section class="hero">
    <p class="eyebrow">Willkommen</p>
    <h1>Tradition, Präzision und Gemeinschaft</h1>
    <p>
      Der Schützenverein Hochdorf 1955 e.V. verbindet sportlichen Anspruch mit
      aktiver Vereinskultur. Hier findest du aktuelle Informationen zu Training,
      Veranstaltungen und Wettkämpfen.
    </p>
  </section>

  <section class="grid" aria-label="Schnelleinstieg">
    <article class="card">
      <h2>Nächste Termine</h2>
      <p>
        Sonntag Frühschoppen und Vereinsbetrieb ab 10:00 Uhr auf der Sandhalde.
      </p>
      <p><a href="/schuetzenhaus">Mehr zum Schützenhaus</a></p>
    </article>
    <article class="card">
      <h2>Ergebnisse</h2>
      <p>Aktuelle Liga- und Meisterschaftsergebnisse unserer Mannschaften.</p>
      <p><a href="/ergebnisse">Zu den Ergebnissen</a></p>
    </article>
    <article class="card">
      <h2>Neu dabei?</h2>
      <p>
        Informiere dich über Probetraining, Ausrüstung und den Mitgliedsantrag.
      </p>
      <p><a href="/mitgliedschaft">Mitglied werden</a></p>
    </article>
  </section>
</Layout>
