---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SV Hochdorf 1955 – Impressum">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-forest-900 to-forest-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <span
        class="inline-block px-3 py-1 text-xs font-semibold tracking-[0.2em] uppercase text-gold-400 border border-gold-500/30 rounded-full mb-4"
        >Rechtliches</span
      >
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Impressum
      </h1>
      <p class="text-lg text-forest-100/80">Angaben gemäß § 5 TMG.</p>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div
      class="bg-white dark:bg-forest-900 rounded-xl shadow-md border border-sand-200 dark:border-forest-700 p-8 space-y-4 text-forest-700/80 dark:text-forest-100/60 leading-relaxed"
    >
      <p class="font-heading font-bold text-lg text-forest-900">
        Schützenverein Hochdorf 1955 e.V.
      </p>
      <p>Sandhalde 2<br />72202 Nagold</p>
      <div class="h-px bg-sand-200 dark:bg-forest-700"></div>
      <p>
        Vertreten durch den Vorstand gemäß § 26 BGB:<br />
        1. Vorsitzender: Klaus Blümle<br />
        2. Vorsitzender: Dieter Gack
      </p>
      <div class="h-px bg-sand-200 dark:bg-forest-700"></div>
      <p>
        Verantwortlich für den Inhalt (gem. § 55 Abs. 2 RStV): Schützenverein
        Hochdorf 1955 e.V., Die Vorstandschaft
      </p>
      <p>
        E-Mail: <a
          href="mailto:kontakt@svh1955.de"
          class="text-gold-500 hover:text-gold-400 underline underline-offset-2"
          >kontakt@svh1955.de</a
        >
      </p>
    </div>
  </section>
</Layout>
